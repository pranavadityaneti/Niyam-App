    <!-- Permission screens (placeholder copy — refined when UI references arrive) -->
    <string name="perm_usage_title">जानें कब आप ब्लॉक किए ऐप खोलते हैं</string>
    <string name="perm_usage_body">यह जानने के लिए कि आप Instagram, Facebook या YouTube कब खोलते हैं — ताकि हम पहले आपका मंत्र दिखा सकें।</string>
    <string name="perm_overlay_title">दूसरे ऐप्स के ऊपर दिखाएँ</string>
    <string name="perm_overlay_body">ब्लॉक किए गए ऐप के ऊपर आपका मंत्र दिखाने के लिए।</string>
    <string name="perm_accessibility_title">ऐप खुलते ही तुरंत पहचानें</string>
    <string name="perm_accessibility_body">यह पहचानने के लिए कि Instagram, Facebook या YouTube ठीक किस पल खुलता है — तुरंत, बिना किसी देरी के।</string>
    <string name="perm_battery_title">हमें बैकग्राउंड में बंद न करें</string>
    <string name="perm_battery_body">ताकि जब आप कहीं और हों, तब आपका फ़ोन नियम को बंद न कर दे।</string>
    <string name="perm_oem_title">बैकग्राउंड गतिविधि की अनुमति दें</string>
    <string name="perm_oem_body_miui">Xiaomi, Redmi और POCO फ़ोन बैकग्राउंड ऐप्स को आक्रामक रूप से बंद कर देते हैं। अनुमति दें पर टैप करें, सूची में नियम ढूँढें और Autostart चालू करें।</string>
    <string name="perm_oem_body_color_os">OPPO और realme फ़ोन बैटरी बचाने के लिए बैकग्राउंड ऐप्स बंद कर देते हैं। अनुमति दें पर टैप करें और नियम को अपने आप शुरू होने की अनुमति दें।</string>
    <string name="perm_oem_body_funtouch_os">vivo और iQOO फ़ोन बैटरी बचाने के लिए बैकग्राउंड ऐप्स बंद कर देते हैं। अनुमति दें पर टैप करें और नियम को बैकग्राउंड में शुरू होने की अनुमति दें।</string>
    <string name="perm_oem_body_oxygen_os">OnePlus फ़ोन बैटरी को आक्रामक रूप से ऑप्टिमाइज़ करते हैं। अनुमति दें पर टैप करें, फिर नियम के बैटरी उपयोग को \"ऑप्टिमाइज़ न करें\" पर सेट करें।</string>
    <string name="perm_oem_body_one_ui">Samsung फ़ोन अनुपयोगी ऐप्स को सुला देते हैं। अनुमति दें पर टैप करें, फिर सुनिश्चित करें कि नियम कभी \"Sleeping apps\" में न जोड़ा जाए।</string>
    <string name="perm_oem_body_generic">कुछ फ़ोन बैटरी बचाने के लिए चुपचाप बैकग्राउंड ऐप्स रोक देते हैं। अगर आपका फ़ोन नियम के लिए Autostart या बैकग्राउंड-गतिविधि का विकल्प दिखाता है, तो उसे चालू करें। अगर कोई विकल्प न दिखे, तो सब ठीक है — हो गया पर टैप करें।</string>

