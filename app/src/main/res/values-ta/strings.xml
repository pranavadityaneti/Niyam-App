    <!-- Permission screens (placeholder copy — refined when UI references arrive) -->
    <string name="perm_usage_title">தடுக்கப்பட்ட செயலிகளைத் திறக்கும்போது அறிய</string>
    <string name="perm_usage_body">நீங்கள் Instagram, Facebook அல்லது YouTube திறக்கும்போது அறிந்து, உங்கள் மந்திரத்தை முதலில் காட்டுவதற்காக.</string>
    <string name="perm_overlay_title">மற்ற செயலிகளுக்கு மேலே காட்ட</string>
    <string name="perm_overlay_body">தடுக்கப்பட்ட செயலிக்கு மேலே உங்கள் மந்திரத்தைக் காட்டுவதற்காக.</string>
    <string name="perm_accessibility_title">செயலிகள் திறப்பதை உடனடியாகக் கண்டறிய</string>
    <string name="perm_accessibility_body">Instagram, Facebook அல்லது YouTube திறக்கும் சரியான கணத்தை — தாமதமின்றி, உடனடியாகக் கண்டறிவதற்காக.</string>
    <string name="perm_battery_title">பின்னணியில் எங்களை நிறுத்திவிடாதீர்கள்</string>
    <string name="perm_battery_body">நீங்கள் வேறு செயலியைப் பயன்படுத்தும்போது உங்கள் தொலைபேசி நியம்-ஐ நிறுத்திவிடாமல் இருக்க.</string>
    <string name="perm_oem_title">பின்னணி செயல்பாட்டை அனுமதிக்கவும்</string>
    <string name="perm_oem_body_miui">Xiaomi, Redmi மற்றும் POCO தொலைபேசிகள் பின்னணி செயலிகளைத் தீவிரமாக மூடிவிடும். அளி என்பதைத் தட்டி, பட்டியலில் நியம்-ஐக் கண்டுபிடித்து, தானியங்கி தொடக்கத்தை இயக்கவும்.</string>
    <string name="perm_oem_body_color_os">OPPO மற்றும் realme தொலைபேசிகள் பேட்டரியைச் சேமிக்க பின்னணி செயலிகளை மூடிவிடும். அளி என்பதைத் தட்டி, நியம்-ஐ தானாகத் தொடங்க அனுமதிக்கவும்.</string>
    <string name="perm_oem_body_funtouch_os">vivo மற்றும் iQOO தொலைபேசிகள் பேட்டரியைச் சேமிக்க பின்னணி செயலிகளை மூடிவிடும். அளி என்பதைத் தட்டி, நியம்-ஐ பின்னணியில் தொடங்க அனுமதிக்கவும்.</string>
    <string name="perm_oem_body_oxygen_os">OnePlus தொலைபேசிகள் பேட்டரியைத் தீவிரமாக மேம்படுத்தும். அளி என்பதைத் தட்டி, பின்னர் நியம்-இன் பேட்டரி பயன்பாட்டை \"மேம்படுத்த வேண்டாம்\" என அமைக்கவும்.</string>
    <string name="perm_oem_body_one_ui">Samsung தொலைபேசிகள் பயன்படுத்தாத செயலிகளை உறங்க வைக்கும். அளி என்பதைத் தட்டி, பின்னர் நியம் ஒருபோதும் \"உறங்கும் செயலிகள்\" பட்டியலில் சேர்க்கப்படவில்லை என்பதை உறுதிசெய்யவும்.</string>
    <string name="perm_oem_body_generic">சில தொலைபேசிகள் பேட்டரியைச் சேமிக்க பின்னணி செயலிகளை அமைதியாக நிறுத்திவிடும். உங்கள் தொலைபேசி நியம்-க்கு தானியங்கி தொடக்கம் அல்லது பின்னணி செயல்பாட்டு விருப்பத்தைக் காட்டினால், அதை இயக்கவும். எதுவும் தென்படவில்லை எனில் எல்லாம் தயார் — முடிந்தது என்பதைத் தட்டவும்.</string>

